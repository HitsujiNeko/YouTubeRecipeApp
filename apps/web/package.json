{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "verify:prepr:auto": "npm run format:check && npm run lint && npm run typecheck && npm run test:unit",
    "verify:prepr:manual-template": "node scripts/prepare-manual-qa.mjs",
    "verify:prepr": "npm run verify:prepr:auto && npm run verify:prepr:manual-template",
    "db:migration:new": "npx supabase migration new",
    "db:push": "npx supabase db push",
    "db:reset:local": "npx supabase db reset"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "next": "16.1.6",
    "openai": "^6.25.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
